# SkyImage 演示站环境变量配置示例
# 此文件用于演示站部署时的环境变量配置参考

# ==========================================
# 基础配置
# ==========================================

# HTTP 服务地址
HTTP_ADDR=:8080

# 存储路径（容器内临时存储）
STORAGE_PATH=storage/uploads

# 公共访问 URL（根据实际部署地址修改）
PUBLIC_BASE_URL=http://localhost:8080

# 前端资源目录
FRONTEND_DIST=dist

# ==========================================
# 数据库配置 - 强制使用 SQLite
# ==========================================

# 数据库类型（演示站强制使用 sqlite）
DATABASE_TYPE=sqlite

# 数据库文件路径（容器内临时存储）
DATABASE_PATH=storage/data/demo.db

# ==========================================
# 用户注册配置
# ==========================================

# 是否允许用户注册（演示站建议设置为 false）
ALLOW_REGISTRATION=false

# ==========================================
# CORS 配置
# ==========================================

# CORS 允许的源（多个源用逗号分隔，演示站可留空）
CORS_ALLOWED_ORIGINS=

# ==========================================
# 可信代理配置
# ==========================================

# 可信代理 CIDR/IP（多个用逗号分隔；留空表示不信任转发头）
TRUSTED_PROXIES=

# ==========================================
# 演示站专用配置
# ==========================================

# 演示站模式标识
DEMO_MODE=true

# 站点名称（可通过环境变量设置）
SITE_NAME=SkyImage Demo

# 管理员用户名（可通过环境变量设置）
ADMIN_USERNAME=admin

# 管理员邮箱（可通过环境变量设置）
ADMIN_EMAIL=admin@example.com

# 管理员密码（可通过环境变量设置，建议至少8位）
ADMIN_PASSWORD=DemoPass123!

# 是否跳过初始化程序（设置为 true 将自动初始化）
SKIP_INSTALL=true

# ==========================================
# 演示站限制配置
# ==========================================

# 最大文件大小（字节，默认 5MB）
MAX_FILE_SIZE=5242880

# 最大存储容量（字节，默认 100MB）
MAX_CAPACITY=104857600

# ==========================================
# 时区配置
# ==========================================

TZ=Asia/Shanghai

# ==========================================
# 重要提示
# ==========================================
# 
# 1. ⚠️  演示站禁止添加任何持久化存储策略配置
# 2. ⚠️  所有数据仅保存在容器内，容器重启后数据将丢失
# 3. ⚠️  演示站仅用于功能展示，不建议用于生产环境
# 4. ⚠️  演示站默认禁止用户注册
# 5. ⚠️  演示站有文件大小和存储容量限制
#
# ==========================================
# 使用方法
# ==========================================
#
# Docker 运行示例：
# docker run -d -p 8080:8080 \
#   -e SITE_NAME="My Demo Site" \
#   -e ADMIN_USERNAME="admin" \
#   -e ADMIN_EMAIL="admin@demo.com" \
#   -e ADMIN_PASSWORD="SecurePass123!" \
#   --name skyimage-demo \
#   your-org/skyimage-demo:demo-latest
#
# Docker Compose 示例：
# version: '3'
# services:
#   skyimage-demo:
#     image: your-org/skyimage-demo:demo-latest
#     ports:
#       - "8080:8080"
#     environment:
#       - SITE_NAME=My Demo Site
#       - ADMIN_USERNAME=admin
#       - ADMIN_EMAIL=admin@demo.com
#       - ADMIN_PASSWORD=SecurePass123!
#       - PUBLIC_BASE_URL=http://your-domain.com
#
# ==========================================