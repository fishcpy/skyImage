HTTP_ADDR=:8080
STORAGE_PATH=storage/uploads
PUBLIC_BASE_URL=http://localhost:8080
ALLOW_REGISTRATION=true
LEGACY_DSN=
FRONTEND_DIST=dist

# Gin mode: release (default) | debug | test
# GIN_MODE=release

# CORS 配置（多个源用逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 可信代理配置（多个 CIDR/IP 用逗号分隔；留空表示不信任转发头）
TRUSTED_PROXIES=

# 数据库配置（安装向导写入；也可手动配置后跳过向导中的数据库步骤）
# DATABASE_TYPE: sqlite | mysql | postgres
DATABASE_TYPE=
# SQLite 文件路径（DATABASE_TYPE=sqlite 时使用）
DATABASE_PATH=
# MySQL / PostgreSQL 连接信息
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=