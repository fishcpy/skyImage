# 演示站专用 Dockerfile
# 特点：
# 1. 强制使用 SQLite 数据库
# 2. 禁止持久化存储策略
# 3. 支持环境变量配置站点信息
# 4. 自动初始化演示站

# 阶段 1: 构建前端
FROM node:18-alpine AS frontend-builder

WORKDIR /app

# 复制前端依赖文件
COPY package.json pnpm-lock.yaml ./

# 安装 pnpm 并安装依赖
RUN npm install -g pnpm && pnpm install --frozen-lockfile

# 复制前端源码
COPY src ./src
COPY index.html ./
COPY vite.config.ts tsconfig.json tsconfig.node.json ./
COPY tailwind.config.ts postcss.config.js components.json ./

# 构建前端
RUN pnpm build

# 阶段 2: 构建后端
FROM golang:1.25-alpine AS backend-builder

WORKDIR /app

# 安装构建依赖
RUN apk add --no-cache gcc musl-dev sqlite-dev

# 复制 Go 依赖文件
COPY go.mod go.sum ./

# 下载依赖
RUN go mod download

# 复制后端源码
COPY cmd ./cmd
COPY internal ./internal
COPY check_url.go ./

# 构建后端（启用 CGO 以支持 SQLite）
RUN CGO_ENABLED=1 GOOS=linux go build -a -installsuffix cgo -o api cmd/api/main.go

# 阶段 3: 最终镜像
FROM alpine:latest

WORKDIR /app

# 安装运行时依赖
RUN apk --no-cache add ca-certificates tzdata sqlite-libs

# 从构建阶段复制文件
COPY --from=backend-builder /app/api .
COPY --from=frontend-builder /app/dist ./dist

# 复制演示站专用启动脚本
COPY docker-entrypoint-demo.sh .
RUN chmod +x docker-entrypoint-demo.sh

# 创建存储目录（临时存储，容器重启后数据将丢失）
RUN mkdir -p storage/uploads storage/data

# 暴露端口
EXPOSE 8080

# 设置演示站专用环境变量
# 构建参数用于设置默认值，运行时可通过环境变量覆盖
ARG DEMO_MODE=true
ARG SITE_NAME=SkyImage Demo
ARG ADMIN_USERNAME=demo_admin
ARG ADMIN_EMAIL=demo@example.com
ARG ADMIN_PASSWORD=DemoPass123!
ARG SKIP_INSTALL=true

ENV HTTP_ADDR=:8080 \
    STORAGE_PATH=storage/uploads \
    FRONTEND_DIST=dist \
    DATABASE_TYPE=sqlite \
    DATABASE_PATH=storage/data/demo.db \
    ALLOW_REGISTRATION=false \
    CORS_ALLOWED_ORIGINS= \
    GIN_MODE=release \
    TZ=Asia/Shanghai \
    DEMO_MODE=${DEMO_MODE} \
    SITE_NAME=${SITE_NAME} \
    ADMIN_USERNAME=${ADMIN_USERNAME} \
    ADMIN_EMAIL=${ADMIN_EMAIL} \
    ADMIN_PASSWORD=${ADMIN_PASSWORD} \
    SKIP_INSTALL=${SKIP_INSTALL} \
    MAX_FILE_SIZE=5242880 \
    MAX_CAPACITY=104857600

# 启动应用
CMD ["./docker-entrypoint-demo.sh"]